#!/usr/bin/env bash
# Hook pre-push: verificação COMPLETA do que vai ser enviado.
# Inclui testes, cobertura, build e o verificador independente (PEV).
set -uo pipefail
ROOT="$(git rev-parse --show-toplevel)"
export HARNESS_DIFF_MODE="range"
echo "› harness: pre-push (verificação completa)"
bash "$ROOT/.harness/verify.sh" --all
status=$?
if [ "$status" -ne 0 ]; then
  echo "› harness: push bloqueado. Veja o relatório acima."
fi
exit $status
