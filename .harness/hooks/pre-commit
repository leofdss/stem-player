#!/usr/bin/env bash
# Hook pre-commit: checagens RÁPIDAS sobre o que está no index.
# Formatação + lint + verifiers de arquitetura. Sem build/cobertura (lentos).
set -uo pipefail
ROOT="$(git rev-parse --show-toplevel)"
export HARNESS_DIFF_MODE="staged"
echo "› harness: pre-commit (rápido, sobre o staged)"
bash "$ROOT/.harness/verify.sh" --quick
status=$?
if [ "$status" -ne 0 ]; then
  echo "› harness: commit bloqueado. Corrija os itens acima ou use 'git commit --no-verify' para emergências."
fi
exit $status
