{
  "name": "stem-player",
  "version": "0.1.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --host=0.0.0.0",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "tauri": "tauri",
    "lint": "eslint \"src/**/*.{ts,html}\"",
    "lint:fix": "eslint \"src/**/*.{ts,html}\" --fix",
    "format": "prettier --write \"src/**/*.{ts,html,css,scss,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,css,scss,json}\"",
    "commitlint": "commitlint --edit",
    "harness": "bash .harness/verify.sh",
    "harness:all": "bash .harness/verify.sh --all",
    "harness:quick": "bash .harness/verify.sh --quick",
    "harness:install": "bash .harness/install.sh",
    "prepare": "git config core.hooksPath .harness/hooks || true",
    "claude": "claude"
  },
  "private": true,
  "dependencies": {
    "@angular/common": "20.1.4",
    "@angular/compiler": "20.1.4",
    "@angular/core": "20.1.4",
    "@angular/forms": "20.1.4",
    "@angular/platform-browser": "20.1.4",
    "@angular/router": "20.1.4",
    "@tauri-apps/api": "2",
    "@tauri-apps/plugin-opener": "2",
    "rxjs": "7.8.2",
    "tslib": "2.8.1",
    "zone.js": "0.15.1"
  },
  "devDependencies": {
    "@angular/build": "20.1.4",
    "@angular/cli": "20.1.4",
    "@angular/compiler-cli": "20.1.4",
    "@anthropic-ai/claude-code": "^2.1.196",
    "@commitlint/cli": "21.1.0",
    "@commitlint/config-conventional": "21.1.0",
    "@eslint/js": "9.9.0",
    "@tauri-apps/cli": "2",
    "angular-eslint": "20.0.0",
    "eslint": "9.9.0",
    "openspec": "0.0.0",
    "prettier": "3.3.0",
    "typescript": "5.8.3",
    "typescript-eslint": "8.0.0"
  }
}
